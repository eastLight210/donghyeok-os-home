{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "donghyeok-os-home",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "donghyeok.net",
      "custom_domain": true
    }
  ],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
